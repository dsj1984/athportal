# =========================================================================
# Athlete Portal Monorepo — Master Environment Template
# =========================================================================
# Copy this to .env (at the root) and individual packages as needed.
#
# Keys with a preceding `# shape: <name>` marker form the foundational
# pre-deploy contract validated by `node scripts/check-env.mjs`. The
# validator parses this file at runtime — adding a key + shape marker
# here extends the contract automatically. Supported shapes:
#   - nonempty               : non-whitespace string
#   - url                    : absolute http(s) URL
#   - cloudflare-account-id  : 32-char lowercase hex string
#
# Un-tagged keys below are advisory configuration documentation and are
# not enforced by check-env. Never commit real secret values here —
# placeholders only.

# 🛡️ Foundational env contract (validated by check-env)
# -------------------------------------------------------------------------
# shape: nonempty
NODE_ENV=development
# shape: url
DATABASE_URL=postgres://user:password@localhost:5432/athportal
# shape: nonempty
CLOUDFLARE_API_TOKEN=cf_token_placeholder
# shape: cloudflare-account-id
CLOUDFLARE_ACCOUNT_ID=00000000000000000000000000000000

# 🌐 API & Base URLs
# -------------------------------------------------------------------------
# Set this to http://localhost:8787 for local dev with Wrangler.
PUBLIC_API_URL=http://localhost:8787
# Use development, staging, or production.
ENVIRONMENT=development

# 🔑 Clerk Authentication
# -------------------------------------------------------------------------
# Get these from the Clerk Dashboard (Settings > API Keys)
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 💳 Stripe Payments
# -------------------------------------------------------------------------
# Get these from the Stripe Dashboard (Developers > API Keys)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# whsec_... from 'stripe listen' (local) or your Webhook Endpoint (prod)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 🎥 Mux Video
# -------------------------------------------------------------------------
# Get these from the Mux Dashboard (Settings > API Access Tokens)
MUX_TOKEN_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MUX_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MUX_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 🗄️ Database (Turso / LibSQL)
# -------------------------------------------------------------------------
# Local dev: file:packages/shared/data/local.db
# Production: libsql://your-db.turso.io
TURSO_URL=file:packages/shared/data/local.db
TURSO_AUTH_TOKEN=your_turso_auth_token

# ⛅ Cloudflare (Deployment & Infrastructure)
# -------------------------------------------------------------------------
CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=your_cloudflare_zone_id

# 🛠️ Local Development & Debugging
# -------------------------------------------------------------------------
# Get an authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken

# These link your personal Clerk user to a seeded 'coach' user in your local DB.
# DEV_EMAILS accepts a comma-separated list of emails for teams with multiple devs.
# Each email gets its own seeded "Developer Admin" profile (coach + athlete multi-hat).
# DEV_CLERK_USER_ID is paired with the FIRST email in DEV_EMAILS.
# DEV_EMAIL is the legacy single-email fallback and is used when DEV_EMAILS is not set.
DEV_EMAILS=user1@example.com,user2@example.com
DEV_EMAIL=user@example.com
DEV_CLERK_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# 🤖 Agentic CI & QA Pipeline
# -------------------------------------------------------------------------
# API key for OpenRouter, Google AI, or OpenAI (used by Auto-Heal Agent)
LLM_API_KEY=your_llm_api_key
# The target for your QA Auto-Heal webhook
AUTO_HEAL_WEBHOOK_URL=https://your-api.com/webhooks/auto-heal

# 📈 Analytics (PostHog)
# -------------------------------------------------------------------------
POSTHOG_API_KEY=your_posthog_api_key

# 🛰️ Sentry — Error tracking (mobile/web)
# -------------------------------------------------------------------------
# DSN is unset locally — the SDK becomes a no-op when blank.
# Mobile (Expo) reads EXPO_PUBLIC_SENTRY_*; web (Astro) reads SENTRY_*.
# SENTRY_RELEASE is the short Git SHA of the build (set by CI).
# SENTRY_AUTH_TOKEN is a secret used only for sourcemap upload at build time.
# Production mobile builds source it from EAS secrets (eas secret:create);
# CI web builds source it from GitHub Actions secrets. Never commit a real
# token.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_RELEASE=
# shape: url
SENTRY_DSN=https://public@sentry.example.invalid/1
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
# shape: nonempty
SENTRY_AUTH_TOKEN=sentry_auth_token_placeholder
SENTRY_ORG=
SENTRY_PROJECT=

# Per-runtime DSNs introduced by Story #255. Each runtime's init wrapper
# (apps/api/src/sentry.ts, apps/web/src/sentry.ts, apps/mobile/src/sentry.ts)
# reads its own key so staging vs production vs runtime-specific noise can
# be routed to distinct Sentry projects without cross-contamination.
# When blank the matching SDK becomes a no-op — local dev stays uninstrumented.
SENTRY_DSN_WORKERS=
SENTRY_DSN_WEB=
SENTRY_DSN_MOBILE=

# 🔥 Observability synthetic-failure rehearsal gate
# -------------------------------------------------------------------------
# Gates the POST /api/v1/_debug/synthetic-failure endpoint (Story #275,
# Tech Spec #246 § "Synthetic-failure endpoint exposure surface"). The
# route returns 404 when this value is anything other than the literal
# string `true` — including unset, `false`, `1`, `TRUE`, or any other
# variant. The gate is set in **staging only** by the rehearsal
# procedure at docs/ops/observability-runbook.md § "Synthetic-failure
# rehearsal" and is unset immediately after the rehearsal completes. The
# value is NEVER set in production.
OBSERVABILITY_SYNTHETIC_FAILURE_ENABLED=false

# 📬 Observability alert channel
# -------------------------------------------------------------------------
# Single operator-email distribution list of record (ADR-012 §
# "Alerting channel"). Every observability vendor — Sentry alert rules,
# Better Stack uptime failure rules, future log-sink anomaly rules —
# routes here. Use a distribution list, not a personal inbox, so on-call
# rotation does not require config changes. Provision per environment:
# distinct addresses (or the same list with environment-tagged subject
# prefixes) for staging vs. production so test alerts do not pollute
# the production triage view.
# Consumed by: infra/uptime/betterstack.yml (alert_destination),
# apps/api/wrangler.toml (Workers secret), Sentry alert-rule config.
OBSERVABILITY_ALERT_EMAIL=ops-alerts@example.invalid

# 📦 Logpush — managed log-sink credential
# -------------------------------------------------------------------------
# Bearer token for the managed log sink (Datadog Logs / Better Stack Logs /
# Axiom — chosen vendor recorded in docs/decisions/0002-log-sink-vendor.md)
# that the Cloudflare Logpush job declared in apps/api/wrangler.toml ships
# the `athportal_request_log` Analytics Engine dataset to.
#
# Stored as a GitHub Actions secret (CI uses it to render the Logpush
# destination URL at deploy time) and as a Cloudflare Workers secret
# (provisioned via `wrangler secret put LOGPUSH_SINK_TOKEN --env
# <staging|production>`). Never committed with a real value — this file
# carries the placeholder only.
LOGPUSH_SINK_TOKEN=logpush_sink_token_placeholder
