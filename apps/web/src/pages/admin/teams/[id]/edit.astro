---
// apps/web/src/pages/admin/teams/[id]/edit.astro
//
// `/admin/teams/:id/edit` — edit-team page (Story #657 / Task #676).
//
// Renders an empty form shell; the inline script GETs
// `/api/v1/admin/teams/:id` to hydrate the initial values, then re-uses
// the shared TeamForm submit machinery (PATCH on submit, redirect to
// the list on success).
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md) — utility
// classes resolve against the @theme tokens declared in
// apps/web/src/styles/global.css; no orphan BEM hooks. Page chrome
// composes the shared PageHeader primitive. Restyled by Story #851 /
// Task #858.

import { requireAdminSsr } from '../../../../lib/ssrAuthGate';

// SSR auth gate (Story #952 F4). Anonymous → 302 /sign-in; signed-in
// non-admin → 404 (non-enumeration per Epic #11 AC-2/AC-3). The page
// chrome must not render to non-admin callers, even though the inline
// client-script fetch would 403 a moment later.
import AppLayout from '../../../../components/layout/AppLayout.astro';
import PageHeader from '../../../../components/ui/PageHeader.astro';
import TeamForm from '../../../../components/admin/teams/TeamForm.astro';

const { id } = Astro.params;
if (typeof id !== 'string' || id.length === 0) {
  return new Response('Not Found', { status: 404 });
}
const action = `/api/v1/admin/teams/${id}`;
const __ssr_gate = await requireAdminSsr(Astro);
if (__ssr_gate) return __ssr_gate;

---

<AppLayout title="Edit team · Admin" role="org_admin" activeHref="/admin/teams">
  <meta name="robots" content="noindex, nofollow" slot="head" />
  <div data-team-id={id} data-admin-teams-edit class="flex flex-col gap-6">
    <PageHeader title="Edit team">
      <a
        slot="actions"
        class="inline-flex items-center justify-center rounded-md border border-border bg-surface-card px-3 py-2 text-sm font-medium text-text-primary shadow-sm hover:bg-surface-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
        href="/admin/teams"
      >
        Back to teams
      </a>
    </PageHeader>

    <p
      class="rounded-md border border-action-coral bg-surface-card px-4 py-3 text-sm text-action-coral"
      data-testid="admin-team-load-error"
      role="alert"
      hidden
    ></p>

    <TeamForm mode="edit" action={action} />
  </div>
</AppLayout>

<script>
  import { TEAM_FORM_TEST_IDS } from '../../../../components/admin/teams/TeamForm.ts';

  interface ApiTeam {
    id: string;
    name: string;
    sport: string;
    season: string;
    ageGroup: string;
    archivedAt: string | null;
  }

  interface ApiEnvelope {
    success: boolean;
    data?: ApiTeam;
    error?: { code?: string; message?: string };
  }

  function hydrate(team: ApiTeam): void {
    const form = document.querySelector<HTMLFormElement>(
      `[data-testid="${TEAM_FORM_TEST_IDS.editForm}"]`,
    );
    if (!form) return;
    form.dataset.initialName = team.name;
    form.dataset.initialSport = team.sport;
    form.dataset.initialSeason = team.season;
    form.dataset.initialAgeGroup = team.ageGroup;
    const fields: ReadonlyArray<[string, string]> = [
      [TEAM_FORM_TEST_IDS.nameInput, team.name],
      [TEAM_FORM_TEST_IDS.sportInput, team.sport],
      [TEAM_FORM_TEST_IDS.seasonInput, team.season],
      [TEAM_FORM_TEST_IDS.ageGroupInput, team.ageGroup],
    ];
    for (const [testId, value] of fields) {
      const input = form.querySelector<HTMLInputElement>(`[data-testid="${testId}"]`);
      if (input) input.value = value;
    }
  }

  async function load(): Promise<void> {
    const root = document.querySelector<HTMLElement>('[data-admin-teams-edit]');
    const errorEl = document.querySelector<HTMLElement>('[data-testid="admin-team-load-error"]');
    const id = root?.dataset.teamId;
    if (!id) return;
    try {
      const res = await fetch(`/api/v1/admin/teams/${encodeURIComponent(id)}`, {
        headers: { accept: 'application/json' },
      });
      const envelope = (await res.json().catch(() => null)) as ApiEnvelope | null;
      if (!res.ok || envelope?.success !== true || !envelope.data) {
        if (errorEl) {
          errorEl.textContent = envelope?.error?.message ?? 'Could not load this team.';
          errorEl.hidden = false;
        }
        return;
      }
      hydrate(envelope.data);
    } catch {
      if (errorEl) {
        errorEl.textContent = 'Could not reach the server.';
        errorEl.hidden = false;
      }
    }
  }

  void load();
</script>
