---
// apps/web/src/pages/admin/teams/index.astro
//
// `/admin/teams` — org-admin Team CRUD landing surface (Story #657 /
// Task #676).
//
// Renders an empty shell server-side; the inline script fetches
// `/api/v1/admin/teams` (or `?archived=true` when the user flips the
// "Show archived" toggle) and renders the resulting rows into the
// table. The active vs archived view is a single round-trip — there is
// no client-side filter of one combined list.
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md). Page chrome
// composes the shared `<AppLayout>` (Story #971 reference adoption)
// for the persona-aware header + user menu, and the `<PageHeader>`
// primitive inside the layout's <main> slot. Table chrome composes
// the shared DataTable primitive — no orphan BEM hooks. Every
// `data-testid` is preserved verbatim because the teams acceptance
// scenarios target those selectors. Restyled by Story #851 /
// Task #858; rebased onto `<AppLayout>` by Story #971.
//
// Authentication & authorization: every `/admin/*` route is gated by
// Clerk's middleware (signed-in users only) AND the API edge's
// `requireRole('org_admin')` gate (the Worker rejects non-admins with
// 403 FORBIDDEN). The page itself does not re-check the role — the
// list-fetch will surface a 403 envelope if the actor is not an admin.

import AppLayout from '../../../components/layout/AppLayout.astro';
import DataTable from '../../../components/ui/DataTable.astro';
import PageHeader from '../../../components/ui/PageHeader.astro';
import { TEAMS_LIST_TEST_IDS } from '../../../components/admin/teams/TeamForm.ts';
import { requireAdminSsr } from '../../../lib/ssrAuthGate';

// SSR auth gate (Story #952 F4). Anonymous → 302 /sign-in; signed-in
// non-admin → 404 (non-enumeration per Epic #11 AC-2/AC-3). The page
// chrome (including the <AppLayout> header) must not render to
// non-admin callers, even though the inline client-script fetch would
// 403 a moment later.
const __ssr_gate = await requireAdminSsr(Astro);
if (__ssr_gate) return __ssr_gate;
---

<AppLayout title="Teams · Admin" role="org_admin" activeHref="/admin/teams">
  <PageHeader title="Teams">
    <a
      slot="actions"
      class="inline-flex items-center justify-center rounded-md bg-brand px-4 py-2 text-sm font-medium text-text-on-brand shadow-sm hover:bg-brand-strong focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
      data-testid={TEAMS_LIST_TEST_IDS.createLink}
      href="/admin/teams/new"
    >
      New team
    </a>
  </PageHeader>
  <span class="sr-only" data-testid="admin-teams-heading">Teams</span>

  <label class="inline-flex items-center gap-2 text-sm text-text-primary">
    <input
      type="checkbox"
      class="h-4 w-4 rounded border border-border text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
      data-testid={TEAMS_LIST_TEST_IDS.showArchivedToggle}
    />
    Show archived
  </label>

  <p
    class="hidden rounded-md border border-action-coral bg-surface-card px-4 py-3 text-sm text-action-coral"
    role="alert"
    data-testid="admin-teams-error"
    hidden
  ></p>

  <DataTable
    testId={TEAMS_LIST_TEST_IDS.list}
    tbodyTestId="admin-teams-tbody"
    columns={[
      { key: 'name', label: 'Name' },
      { key: 'sport', label: 'Sport' },
      { key: 'season', label: 'Season' },
      { key: 'age-group', label: 'Age group' },
      { key: 'actions', label: 'Actions', align: 'end' },
    ]}
  />

  <p
    class="hidden rounded-xl border border-border bg-surface-card px-6 py-10 text-center text-sm text-text-secondary"
    data-testid={TEAMS_LIST_TEST_IDS.emptyState}
    hidden
  >
    No teams to show.
  </p>
</AppLayout>

<script>
  import { TEAMS_LIST_TEST_IDS as TEST_IDS } from '../../../components/admin/teams/TeamForm.ts';

  interface ApiTeam {
    id: string;
    name: string;
    sport: string;
    season: string;
    ageGroup: string;
    archivedAt: string | null;
  }

  interface ApiEnvelope {
    success: boolean;
    data?: ApiTeam[];
    error?: { code?: string; message?: string };
  }

  const toggle = document.querySelector<HTMLInputElement>(
    `[data-testid="${TEST_IDS.showArchivedToggle}"]`,
  );
  const tbody = document.querySelector<HTMLTableSectionElement>('[data-testid="admin-teams-tbody"]');
  const heading = document.querySelector<HTMLElement>('[data-testid="admin-teams-heading"]');
  const empty = document.querySelector<HTMLElement>(`[data-testid="${TEST_IDS.emptyState}"]`);
  const errorEl = document.querySelector<HTMLElement>('[data-testid="admin-teams-error"]');

  function escapeHtml(value: string): string {
    return value.replace(/[&<>"']/g, (ch) => {
      switch (ch) {
        case '&': return '&amp;';
        case '<': return '&lt;';
        case '>': return '&gt;';
        case '"': return '&quot;';
        case "'": return '&#39;';
        default: return ch;
      }
    });
  }

  function renderRows(teams: ReadonlyArray<ApiTeam>): void {
    if (!tbody) return;
    if (teams.length === 0) {
      tbody.innerHTML = '';
      if (empty) empty.hidden = false;
      return;
    }
    if (empty) empty.hidden = true;
    tbody.innerHTML = teams
      .map((t) => {
        const safeName = escapeHtml(t.name);
        const safeSport = escapeHtml(t.sport);
        const safeSeason = escapeHtml(t.season);
        const safeAgeGroup = escapeHtml(t.ageGroup);
        const safeId = encodeURIComponent(t.id);
        const archiveLabel = t.archivedAt ? 'Restore' : 'Archive';
        const archiveTestId = t.archivedAt
          ? 'admin-team-restore-btn'
          : TEST_IDS.archiveButton;
        return `<tr class="text-sm text-text-primary [&_td]:px-3 [&_td]:py-2" data-testid="${TEST_IDS.row}" data-team-id="${escapeHtml(t.id)}">
            <td>${safeName}</td>
            <td>${safeSport}</td>
            <td>${safeSeason}</td>
            <td>${safeAgeGroup}</td>
            <td class="text-right">
              <a class="mr-3 text-brand hover:underline" data-testid="${TEST_IDS.editLink}" href="/admin/teams/${safeId}/edit">Edit</a>
              <button class="inline-flex items-center justify-center rounded-md border border-border bg-surface-card px-2 py-1 text-xs text-text-primary hover:bg-surface-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand" type="button" data-testid="${archiveTestId}" data-team-id="${escapeHtml(t.id)}">${archiveLabel}</button>
            </td>
          </tr>`;
      })
      .join('');
  }

  function setHeading(showingArchived: boolean): void {
    if (heading) heading.textContent = showingArchived ? 'Archived teams' : 'Teams';
  }

  async function load(): Promise<void> {
    const showingArchived = toggle?.checked === true;
    setHeading(showingArchived);
    if (errorEl) {
      errorEl.textContent = '';
      errorEl.hidden = true;
    }
    try {
      const url = showingArchived ? '/api/v1/admin/teams?archived=true' : '/api/v1/admin/teams';
      const res = await fetch(url, { headers: { accept: 'application/json' } });
      const envelope = (await res.json().catch(() => null)) as ApiEnvelope | null;
      if (!res.ok || envelope?.success !== true || !envelope.data) {
        if (errorEl) {
          errorEl.textContent = envelope?.error?.message ?? 'Could not load teams.';
          errorEl.hidden = false;
        }
        renderRows([]);
        return;
      }
      renderRows(envelope.data);
    } catch {
      if (errorEl) {
        errorEl.textContent = 'Could not reach the server.';
        errorEl.hidden = false;
      }
      renderRows([]);
    }
  }

  toggle?.addEventListener('change', () => {
    void load();
  });

  document.addEventListener('click', async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const isArchive = target.dataset.testid === TEST_IDS.archiveButton;
    const isRestore = target.dataset.testid === 'admin-team-restore-btn';
    if (!isArchive && !isRestore) return;
    const teamId = target.dataset.teamId;
    if (!teamId) return;
    const verbPath = isArchive ? 'archive' : 'restore';
    try {
      const res = await fetch(
        `/api/v1/admin/teams/${encodeURIComponent(teamId)}/${verbPath}`,
        { method: 'POST' },
      );
      if (res.ok) {
        await load();
      } else if (errorEl) {
        const envelope = (await res.json().catch(() => null)) as ApiEnvelope | null;
        errorEl.textContent = envelope?.error?.message ?? 'Could not update the team.';
        errorEl.hidden = false;
      }
    } catch {
      if (errorEl) {
        errorEl.textContent = 'Could not reach the server.';
        errorEl.hidden = false;
      }
    }
  });

  void load();
</script>
