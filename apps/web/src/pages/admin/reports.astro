---
// apps/web/src/pages/admin/reports.astro
//
// `/admin/reports` — org-admin landing surface for the
// verified-achievement aggregation report (Epic #10 / Story #679 /
// Task #699; restyled under Epic #828 / Story #843 / Task #854).
//
// Renders the empty shells server-side; the inline script fetches
// `/api/v1/admin/reports/verified-achievements` and renders the
// resulting rows into the two tables via `renderByTeamRows` /
// `renderBySportRows` from the sibling `VerifiedAchievementReport.ts`
// module.
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md). Page chrome
// is composed via the shared `PageHeader` primitive and each report
// section's table chrome via the shared `DataTable` primitive — no
// orphan BEM hooks. Every `data-testid` on the surface is preserved
// verbatim because the verified-achievement-report contract tests
// (`VerifiedAchievementReport.test.ts`) and the admin acceptance
// scenarios target those selectors.
//
// Authentication & authorization: every `/admin/*` route is gated by
// Clerk's middleware (signed-in users only) AND the API edge's
// `requireRole('org_admin')` gate (the Worker rejects non-admins with
// 403 FORBIDDEN). The page itself does not re-check the role — the
// fetch will surface an error envelope if the actor is not an admin.

import { requireAdminSsr } from '../../lib/ssrAuthGate';

// SSR auth gate (Story #952 F4). Anonymous → 302 /sign-in; signed-in
// non-admin → 404 (non-enumeration per Epic #11 AC-2/AC-3). The page
// chrome must not render to non-admin callers, even though the inline
// client-script fetch would 403 a moment later.
import DataTable from '../../components/ui/DataTable.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import { REPORT_TEST_IDS } from '../../components/admin/reports/VerifiedAchievementReport.ts';
const __ssr_gate = await requireAdminSsr(Astro);
if (__ssr_gate) return __ssr_gate;

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Reports · Admin</title>
  </head>
  <body class="bg-surface-page text-text-primary">
    <main class="mx-auto flex max-w-6xl flex-col gap-6 px-4 py-8 sm:px-6 lg:px-8">
      <PageHeader title="Verified achievements" />
      <span class="sr-only" data-testid="admin-report-heading">Verified achievements</span>

      <p
        class="hidden rounded-md border border-danger bg-danger-soft px-4 py-3 text-sm text-danger"
        role="alert"
        data-testid={REPORT_TEST_IDS.error}
        hidden
      ></p>

      <section class="flex flex-col gap-3" aria-label="By team">
        <h2 class="font-display text-lg font-semibold text-text-primary">By team</h2>
        <DataTable
          testId={REPORT_TEST_IDS.byTeamTable}
          tbodyTestId={REPORT_TEST_IDS.byTeamTbody}
          columns={[
            { key: 'team', label: 'Team' },
            { key: 'verified-achievements', label: 'Verified achievements', align: 'end' },
          ]}
        />
      </section>

      <section class="flex flex-col gap-3" aria-label="By sport">
        <h2 class="font-display text-lg font-semibold text-text-primary">By sport</h2>
        <DataTable
          testId={REPORT_TEST_IDS.bySportTable}
          tbodyTestId={REPORT_TEST_IDS.bySportTbody}
          columns={[
            { key: 'sport', label: 'Sport' },
            { key: 'verified-achievements', label: 'Verified achievements', align: 'end' },
          ]}
        />
      </section>

      <p
        class="hidden rounded-xl border border-border bg-surface-card px-6 py-10 text-center text-sm text-text-secondary"
        data-testid={REPORT_TEST_IDS.emptyState}
        hidden
      >
        No verified achievements to show.
      </p>
    </main>
  </body>
</html>

<script lang="ts">
  import {
    REPORT_TEST_IDS as TEST_IDS,
    renderBySportRows,
    renderByTeamRows,
    type VerifiedAchievementReportPayload,
  } from '../../components/admin/reports/VerifiedAchievementReport.ts';

  interface ReportEnvelope {
    success: boolean;
    data?: VerifiedAchievementReportPayload;
    error?: { code: string; message: string };
  }

  const byTeamBody = document.querySelector<HTMLTableSectionElement>(
    `[data-testid="${TEST_IDS.byTeamTbody}"]`,
  );
  const bySportBody = document.querySelector<HTMLTableSectionElement>(
    `[data-testid="${TEST_IDS.bySportTbody}"]`,
  );
  const empty = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.emptyState}"]`,
  );
  const errorEl = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.error}"]`,
  );

  function showError(message: string): void {
    if (!errorEl) return;
    errorEl.textContent = message;
    errorEl.hidden = false;
  }

  function clearError(): void {
    if (!errorEl) return;
    errorEl.textContent = '';
    errorEl.hidden = true;
  }

  async function loadReport(): Promise<void> {
    if (!byTeamBody || !bySportBody || !empty) return;
    clearError();
    let res: Response;
    try {
      res = await fetch('/api/v1/admin/reports/verified-achievements', {
        credentials: 'same-origin',
        headers: { accept: 'application/json' },
      });
    } catch {
      showError('Network error loading report.');
      return;
    }
    let body: ReportEnvelope;
    try {
      body = (await res.json()) as ReportEnvelope;
    } catch {
      showError('Unexpected server response.');
      return;
    }
    if (!res.ok || !body.success || !body.data) {
      showError(body.error?.message ?? 'Unable to load report.');
      return;
    }
    const report = body.data;
    renderByTeamRows(byTeamBody, report.byTeam);
    renderBySportRows(bySportBody, report.bySport);
    empty.hidden = report.byTeam.length > 0 || report.bySport.length > 0;
  }

  void loadReport();
</script>
