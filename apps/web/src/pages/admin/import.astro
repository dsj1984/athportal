---
// apps/web/src/pages/admin/import.astro
//
// `/admin/import` — admin CSV import landing page (Epic #10 / Story
// #663 / Task #689; rebased onto `<AppLayout>` and extended with the
// "Import history" list by Story #974). Composes:
//
//   - `<CsvMappingTool>` — upload + parse + map + preview + commit
//     island (Story #663).
//   - `<ImportHistory>` — read-only list of prior `csv_import_batches`
//     for the actor's org (Story #974 F2). Fed by
//     `GET /api/v1/admin/csv-import/batches` (Story #973 F1).
//
// Auth: this page is reachable only when the actor passes the
// `requireRole('org_admin')` gate on `/api/v1/admin/*`. The web
// runtime carries the session cookie via Clerk so fetches from the
// island arrive at the API edge already authenticated.
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md). Page
// chrome composes the shared `<AppLayout>` (Story #971 reference
// adoption) for the persona-aware header + user menu and the
// canonical `<PageHeader>` primitive inside the layout's <main> slot.

import AppLayout from '../../components/layout/AppLayout.astro';
import CsvMappingTool from '../../components/admin/CsvMappingTool.astro';
import ImportHistory from '../../components/admin/ImportHistory.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import { requireAdminSsr } from '../../lib/ssrAuthGate';

// SSR auth gate (Story #952 F4). Anonymous → 302 /sign-in; signed-in
// non-admin → 404 (non-enumeration per Epic #11 AC-2/AC-3). The page
// chrome (including the <AppLayout> header) must not render to non-
// admin callers, even though the inline client-script fetch would
// 403 a moment later.
const __ssr_gate = await requireAdminSsr(Astro);
if (__ssr_gate) return __ssr_gate;
---

<AppLayout title="Import roster · Admin" role="org_admin" activeHref="/admin/import">
  <PageHeader
    title="Import roster"
    intro="Upload a CSV of athletes; map each column to a target field; then commit the import. Existing platform accounts are re-used automatically."
  />
  <CsvMappingTool />
  <ImportHistory />
</AppLayout>

<script>
  import {
    IMPORT_HISTORY_TEST_IDS as TEST_IDS,
    renderImportHistoryRows,
  } from '../../components/admin/ImportHistory.ts';
  import type { CsvImportBatchListOutput } from '@repo/shared/schemas/admin/csvImport';

  interface HistoryEnvelope {
    success: boolean;
    data?: CsvImportBatchListOutput;
    error?: { code: string; message: string };
  }

  const tbody = document.querySelector<HTMLTableSectionElement>(
    `[data-testid="${TEST_IDS.tbody}"]`,
  );
  const empty = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.emptyState}"]`,
  );
  const errorEl = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.error}"]`,
  );

  function showError(message: string): void {
    if (!errorEl) return;
    errorEl.textContent = message;
    errorEl.hidden = false;
  }

  function clearError(): void {
    if (!errorEl) return;
    errorEl.textContent = '';
    errorEl.hidden = true;
  }

  async function loadHistory(): Promise<void> {
    if (!tbody || !empty) return;
    clearError();
    let res: Response;
    try {
      res = await fetch('/api/v1/admin/csv-import/batches', {
        credentials: 'same-origin',
        headers: { accept: 'application/json' },
      });
    } catch {
      showError('Network error loading import history.');
      return;
    }
    let body: HistoryEnvelope;
    try {
      body = (await res.json()) as HistoryEnvelope;
    } catch {
      showError('Unexpected server response.');
      return;
    }
    if (!res.ok || !body.success || !body.data) {
      showError(body.error?.message ?? 'Unable to load import history.');
      return;
    }
    const batches = body.data.batches;
    renderImportHistoryRows(tbody, batches);
    empty.hidden = batches.length > 0;
  }

  // Refresh after a successful commit so the operator immediately
  // sees the new batch without a manual reload. `CsvMappingTool`
  // dispatches an `admin-csv-import:commit-succeeded` CustomEvent on
  // `document` when the commit endpoint returns 200. Tolerate the
  // event being missing (older builds of the island) — initial load
  // still happens below.
  document.addEventListener('admin-csv-import:commit-succeeded', () => {
    void loadHistory();
  });

  void loadHistory();
</script>
