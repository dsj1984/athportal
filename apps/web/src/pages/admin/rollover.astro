---
// apps/web/src/pages/admin/rollover.astro
//
// `/admin/rollover` — org-admin landing surface for the season-rollover
// builder (Epic #10 / Story #665 / Task #696).
//
// The page renders an empty shell server-side; the inline script
// drives:
//
//   1. Source/target season inputs (the operator names the seasons
//      they are rolling out of and into).
//   2. A "load" pass that fetches the current source-season roster
//      from `/api/v1/admin/roster?sport=…` — the roster endpoint is
//      reused as a read source for the decisions table because the
//      rollover API itself is write-only (preview + commit), it does
//      not enumerate the source memberships separately.
//   3. The decisions table where the operator marks each membership
//      as promote / archive / transfer and optionally picks a target
//      team id.
//   4. Preview — POSTs the choices to `/api/v1/admin/rollover/preview`
//      and renders the returned plan diff into `data-testid=admin-rollover-diff`.
//   5. Commit — POSTs choices + the canonical expectedPlan back to
//      `/api/v1/admin/rollover/commit`. On 200, renders the applied
//      counts into `data-testid=admin-rollover-status`. On 409
//      STALE_PLAN, surfaces an error inviting the operator to re-run
//      preview.
//
// Authentication & authorization: every `/admin/*` route is gated by
// Clerk's middleware (signed-in users only) AND the API edge's
// `requireRole('org_admin')` gate (the Worker rejects non-admins with
// 403 FORBIDDEN). The page itself does not re-check the role — the
// preview/commit fetches will surface a 403 envelope if the actor is
// not an admin.
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md) — utility
// classes resolve against the @theme tokens declared in
// apps/web/src/styles/global.css; no orphan BEM hooks. Page chrome
// composes the shared `<AppLayout>` (Story #971 reference adoption,
// extended to this surface by Story #1086 so the org-admin can reach
// every other `/admin/*` surface from the shared header) with the
// canonical PageHeader primitive inside the layout's <main> slot; the
// initial diff placeholder composes EmptyState (Story #844 /
// Task #855). The page keeps its `noindex` robots directive via
// AppLayout's `head` slot.

import { requireAdminSsr } from '../../lib/ssrAuthGate';

// SSR auth gate (Story #952 F4). Anonymous → 302 /sign-in; signed-in
// non-admin → 404 (non-enumeration per Epic #11 AC-2/AC-3). The page
// chrome must not render to non-admin callers, even though the inline
// client-script fetch would 403 a moment later.
import AppLayout from '../../components/layout/AppLayout.astro';
import EmptyState from '../../components/ui/EmptyState.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import { ROLLOVER_TEST_IDS } from '../../components/admin/rollover/RolloverPreview.ts';
const __ssr_gate = await requireAdminSsr(Astro);
if (__ssr_gate) return __ssr_gate;

---

<AppLayout title="Season rollover · Admin" role="org_admin" activeHref="/admin/rollover">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <PageHeader title="Season rollover" />

      <section
        class="flex flex-wrap items-end gap-4 rounded-xl border border-border bg-surface-card p-6 shadow-sm"
        aria-label="Season selection"
      >
        <label class="flex min-w-48 flex-1 flex-col gap-1 text-sm font-medium text-text-primary">
          Source season
          <input
            type="text"
            class="rounded-md border border-border bg-surface-bg px-3 py-2 text-sm text-text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
            data-testid={ROLLOVER_TEST_IDS.sourceSeason}
            placeholder="e.g. Fall 2026"
          />
        </label>
        <label class="flex min-w-48 flex-1 flex-col gap-1 text-sm font-medium text-text-primary">
          Target season
          <input
            type="text"
            class="rounded-md border border-border bg-surface-bg px-3 py-2 text-sm text-text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
            data-testid={ROLLOVER_TEST_IDS.targetSeason}
            placeholder="e.g. Fall 2027"
          />
        </label>
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-md bg-brand px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-brand-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
          data-testid="admin-rollover-load-btn"
        >
          Load roster
        </button>
      </section>

      <p
        class="rounded-md border border-action-coral bg-surface-card px-4 py-3 text-sm text-action-coral"
        data-testid={ROLLOVER_TEST_IDS.error}
        hidden
      ></p>

      <div class="overflow-x-auto rounded-xl border border-border bg-surface-card shadow-sm">
        <table
          class="w-full border-collapse text-sm text-text-secondary [&_th]:bg-surface-bg [&_th]:px-3 [&_th]:py-2 [&_th]:text-left [&_th]:font-medium [&_th]:text-text-primary [&_td]:border-t [&_td]:border-border [&_td]:px-3 [&_td]:py-2 [&_input]:rounded-md [&_input]:border [&_input]:border-border [&_input]:bg-surface-bg [&_input]:px-2 [&_input]:py-1 [&_input]:text-sm [&_select]:rounded-md [&_select]:border [&_select]:border-border [&_select]:bg-surface-bg [&_select]:px-2 [&_select]:py-1 [&_select]:text-sm"
          data-testid={ROLLOVER_TEST_IDS.decisions}
        >
          <thead>
            <tr>
              <th>Athlete</th>
              <th>Source team</th>
              <th>Decision</th>
              <th>Target team</th>
            </tr>
          </thead>
          <tbody data-testid="admin-rollover-decisions-tbody"></tbody>
        </table>
      </div>

      <div class="flex flex-wrap gap-3">
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-md bg-brand px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-brand-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
          data-testid={ROLLOVER_TEST_IDS.previewBtn}
        >
          Preview
        </button>
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-md border border-border bg-surface-card px-4 py-2 text-sm font-medium text-text-primary shadow-sm hover:bg-surface-bg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand disabled:cursor-not-allowed disabled:opacity-50"
          data-testid={ROLLOVER_TEST_IDS.commitBtn}
          disabled
        >
          Commit
        </button>
      </div>

      <section
        class="rounded-xl border border-border bg-surface-card p-6 shadow-sm [&_h2]:font-display [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:text-text-primary [&_p]:mt-2 [&_p]:text-sm [&_p]:text-text-secondary [&_ul]:mt-3 [&_ul]:flex [&_ul]:flex-col [&_ul]:gap-1 [&_ul]:text-sm [&_ul]:text-text-secondary [&_li]:rounded-md [&_li]:bg-surface-bg [&_li]:px-3 [&_li]:py-2"
        data-testid={ROLLOVER_TEST_IDS.diff}
      >
        <EmptyState
          title="No preview yet"
          body="Load the source-season roster, mark each athlete promote / archive / transfer, then run Preview to see the planned writes."
        />
      </section>

      <p
        class="text-sm text-text-secondary"
        data-testid={ROLLOVER_TEST_IDS.status}
      ></p>
</AppLayout>

<script>
  import {
    ROLLOVER_TEST_IDS as TEST_IDS,
    collectDecisionDrafts,
    renderCommitStatus,
    renderDecisionRows,
    renderPlanDiff,
    syncTargetTeamForDecision,
    type RolloverDecision,
    type RolloverMembershipRow,
    type RolloverPlanView,
  } from '../../components/admin/rollover/RolloverPreview.ts';

  interface RosterItemWire {
    // Story #972 F1 — roster projection now surfaces the membership id
    // directly; the rollover planner keys on it. The pre-#972 form had
    // to synthesize a key from athleteId, which the planner rejected
    // with UNKNOWN_MEMBERSHIP and silently broke the whole surface.
    membershipId: string;
    athleteId: string;
    fullName: string;
    teamId: string;
    teamName: string;
    sport: string;
    ageGroup: string;
    verifiedAchievementCount: number;
  }

  interface RosterPageWire {
    success: boolean;
    data?: { items: RosterItemWire[]; nextCursor: string | null };
    error?: { code: string; message: string };
  }

  interface PreviewResponse {
    success: boolean;
    data?: { plan: RolloverPlanView };
    error?: { code: string; message: string };
  }

  interface CommitResponse {
    success: boolean;
    data?: {
      applied: { archived: number; promoted: number; errors: number };
      plan: RolloverPlanView;
    };
    error?: { code: string; message: string };
  }

  // Cached state read by preview + commit.
  let lastPlan: RolloverPlanView | null = null;

  const sourceInput = document.querySelector<HTMLInputElement>(
    `[data-testid="${TEST_IDS.sourceSeason}"]`,
  );
  const targetInput = document.querySelector<HTMLInputElement>(
    `[data-testid="${TEST_IDS.targetSeason}"]`,
  );
  const loadBtn = document.querySelector<HTMLButtonElement>(
    '[data-testid="admin-rollover-load-btn"]',
  );
  const tbody = document.querySelector<HTMLTableSectionElement>(
    '[data-testid="admin-rollover-decisions-tbody"]',
  );
  const previewBtn = document.querySelector<HTMLButtonElement>(
    `[data-testid="${TEST_IDS.previewBtn}"]`,
  );
  const commitBtn = document.querySelector<HTMLButtonElement>(
    `[data-testid="${TEST_IDS.commitBtn}"]`,
  );
  const diffEl = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.diff}"]`,
  );
  const statusEl = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.status}"]`,
  );
  const errorEl = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.error}"]`,
  );

  function showError(message: string): void {
    if (!errorEl) return;
    errorEl.textContent = message;
    errorEl.hidden = false;
  }

  function clearError(): void {
    if (!errorEl) return;
    errorEl.textContent = '';
    errorEl.hidden = true;
  }

  async function loadRoster(): Promise<void> {
    if (!tbody || !sourceInput) return;
    clearError();
    let res: Response;
    try {
      res = await fetch('/api/v1/admin/roster', {
        credentials: 'same-origin',
        headers: { accept: 'application/json' },
      });
    } catch {
      showError('Network error loading roster.');
      return;
    }
    let body: RosterPageWire;
    try {
      body = (await res.json()) as RosterPageWire;
    } catch {
      showError('Unexpected server response.');
      return;
    }
    if (!res.ok || !body.success || !body.data) {
      showError(body.error?.message ?? 'Unable to load roster.');
      return;
    }
    // Story #972 F1 — use the membership id the roster projection
    // surfaces. The planner keys on it; any synthesized substitute
    // fails the UNKNOWN_MEMBERSHIP check and breaks the whole surface.
    const rows: RolloverMembershipRow[] = body.data.items.map((item) => ({
      membershipId: item.membershipId,
      athleteName: item.fullName,
      sourceTeamId: item.teamId,
      sourceTeamName: item.teamName,
    }));
    renderDecisionRows(tbody, rows);
    // Wire each row's decision <select> so flipping
    // promote / archive / transfer auto-shapes the Target team field
    // per Story #972 F3.
    const decisionSelects = tbody.querySelectorAll<HTMLSelectElement>(
      `[data-testid="${TEST_IDS.decisionSelect}"]`,
    );
    decisionSelects.forEach((select) => {
      select.addEventListener('change', () => {
        const row = select.closest<HTMLTableRowElement>('tr');
        if (!row) return;
        syncTargetTeamForDecision(row, select.value as RolloverDecision);
      });
    });
    // Clear any stale plan / commit-disabled state from a prior load.
    lastPlan = null;
    if (commitBtn) commitBtn.disabled = true;
  }

  async function runPreview(): Promise<void> {
    if (!tbody || !sourceInput || !targetInput || !diffEl || !commitBtn) return;
    clearError();
    const choices = collectDecisionDrafts(tbody);
    let res: Response;
    try {
      res = await fetch('/api/v1/admin/rollover/preview', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          sourceSeason: sourceInput.value.trim(),
          targetSeason: targetInput.value.trim(),
          choices,
        }),
      });
    } catch {
      showError('Network error during preview.');
      return;
    }
    let body: PreviewResponse;
    try {
      body = (await res.json()) as PreviewResponse;
    } catch {
      showError('Unexpected server response during preview.');
      return;
    }
    if (!res.ok || !body.success || !body.data) {
      showError(body.error?.message ?? 'Preview failed.');
      return;
    }
    lastPlan = body.data.plan;
    renderPlanDiff(diffEl, lastPlan);
    // Story #972 F2 — Commit is only enabled when the preview reports
    // zero errors. Allowing a commit against an errored preview lets
    // the operator "apply" a plan with no writes and still see the
    // success-toned "Applied" status line, which is exactly the
    // silently-broken UX that Story #972 fixes.
    if (lastPlan.errors.length > 0) {
      commitBtn.disabled = true;
      showError(
        `Resolve ${lastPlan.errors.length} preview error${
          lastPlan.errors.length === 1 ? '' : 's'
        } before committing.`,
      );
    } else {
      commitBtn.disabled = false;
    }
  }

  async function runCommit(): Promise<void> {
    if (!tbody || !sourceInput || !targetInput || !statusEl) return;
    if (!lastPlan) {
      showError('Run preview before committing.');
      return;
    }
    clearError();
    const choices = collectDecisionDrafts(tbody);
    let res: Response;
    try {
      res = await fetch('/api/v1/admin/rollover/commit', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          sourceSeason: sourceInput.value.trim(),
          targetSeason: targetInput.value.trim(),
          choices,
          expectedPlan: lastPlan,
        }),
      });
    } catch {
      showError('Network error during commit.');
      return;
    }
    let body: CommitResponse;
    try {
      body = (await res.json()) as CommitResponse;
    } catch {
      showError('Unexpected server response during commit.');
      return;
    }
    if (!res.ok || !body.success || !body.data) {
      showError(body.error?.message ?? 'Commit failed.');
      return;
    }
    renderCommitStatus(statusEl, body.data.applied);
  }

  loadBtn?.addEventListener('click', () => {
    void loadRoster();
  });
  previewBtn?.addEventListener('click', () => {
    void runPreview();
  });
  commitBtn?.addEventListener('click', () => {
    void runCommit();
  });
</script>
