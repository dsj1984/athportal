---
// apps/web/src/pages/admin/org.astro
//
// `/admin/org` — admin org-config landing page (Epic #10 / Story #656
// / Task #674). Composes the `OrgConfigForm` island which persists via
// `PATCH /api/v1/admin/org`, and routes logo uploads through the R2
// signed-URL + finalize endpoints.
//
// The page renders an empty-loader skeleton server-side; the inline
// script block below fetches `GET /api/v1/admin/org` on mount and
// hydrates every controlled input by its `data-testid` selector, then
// fires an `input` event so the form's existing
// `evaluateOrgConfigFormState` re-runs against the hydrated values.
//
// This mirrors the inline-fetch pattern used by every other admin
// page (`/admin/teams`, `/admin/reports`, `/admin/roster`,
// `/admin/rollover`, `/admin/import`, `/admin/invitations`) so the
// `/admin/*` surface is uniformly client-driven for its initial data
// load. Story #878 / Task #892 — Web runtime DB binding cutover.
//
// The PRD-defined data-testid surface is preserved verbatim — every
// id declared in `OrgConfigForm.ts` (`form`, `status`, `submit`,
// `name`, `primaryColor`, `logo`, `formError`) is still emitted by
// the form component below.
//
// Authentication & authorization: every `/admin/*` route is gated by
// Clerk's middleware (signed-in users only) AND the API edge's
// `requireRole('org_admin')` gate (the Worker rejects non-admins with
// 403 FORBIDDEN). The page itself does not re-check the role — the
// fetch will surface an error envelope if the actor is not an admin.
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md) — utility
// classes resolve against the @theme tokens declared in
// apps/web/src/styles/global.css; no orphan BEM hooks. Page chrome is
// composed from the canonical PageHeader primitive (Story #836).

import { requireAdminSsr } from '../../lib/ssrAuthGate';

// SSR auth gate (Story #952 F4). Anonymous → 302 /sign-in; signed-in
// non-admin → 404 (non-enumeration per Epic #11 AC-2/AC-3). The page
// chrome must not render to non-admin callers, even though the inline
// client-script fetch would 403 a moment later.
import OrgConfigForm from '../../components/admin/OrgConfigForm.astro';
import type { OrgConfigLoaderPayload } from '../../components/admin/OrgConfigForm.ts';
import PageHeader from '../../components/ui/PageHeader.astro';

/**
 * Server-side skeleton loader — every nullable field starts null and
 * the inputs render with empty defaults. The inline script block
 * below fetches the real values from `GET /api/v1/admin/org` and
 * hydrates the inputs on mount.
 */
const skeletonLoader: OrgConfigLoaderPayload = {
  id: '',
  name: '',
  sports: [],
  contactEmail: null,
  contactPhone: null,
  primaryColorHex: null,
  logoUrl: null,
};
const __ssr_gate = await requireAdminSsr(Astro);
if (__ssr_gate) return __ssr_gate;

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Organization configuration</title>
  </head>
  <body>
    <main class="mx-auto flex w-full max-w-3xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
      <PageHeader
        title="Organization configuration"
        intro="Update your organization’s public profile, brand colour, and logo."
      />
      <OrgConfigForm loader={skeletonLoader} />
    </main>
  </body>
</html>

<script lang="ts">
  import { ORG_CONFIG_FORM_TEST_IDS as TEST_IDS } from '../../components/admin/OrgConfigForm.ts';

  interface ApiOrgConfig {
    id: string;
    name: string;
    sports: ReadonlyArray<string>;
    contactEmail: string | null;
    contactPhone: string | null;
    primaryColorHex: string | null;
    logoUrl: string | null;
  }

  interface ApiEnvelope {
    success: boolean;
    data?: ApiOrgConfig;
    error?: { code?: string; message?: string };
  }

  const nameInput = document.querySelector<HTMLInputElement>(
    `[data-testid="${TEST_IDS.name}"]`,
  );
  const primaryColorInput = document.querySelector<HTMLInputElement>(
    `[data-testid="${TEST_IDS.primaryColor}"]`,
  );
  const contactEmailInput = document.querySelector<HTMLInputElement>(
    '[data-testid="admin-org-contact-email-input"]',
  );
  const contactPhoneInput = document.querySelector<HTMLInputElement>(
    '[data-testid="admin-org-contact-phone-input"]',
  );
  const sportsList = document.querySelector<HTMLElement>(
    '[data-testid="admin-org-sports-list"]',
  );
  const formError = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.formError}"]`,
  );
  const form = document.querySelector<HTMLFormElement>(
    `[data-testid="${TEST_IDS.form}"]`,
  );

  function showFormError(message: string): void {
    if (!formError) return;
    formError.textContent = message;
    formError.hidden = false;
  }

  function clearFormError(): void {
    if (!formError) return;
    formError.textContent = '';
    formError.hidden = true;
  }

  function escapeHtml(value: string): string {
    return value.replace(/[&<>"']/g, (ch) => {
      switch (ch) {
        case '&': return '&amp;';
        case '<': return '&lt;';
        case '>': return '&gt;';
        case '"': return '&quot;';
        case "'": return '&#39;';
        default: return ch;
      }
    });
  }

  function hydrateSports(sports: ReadonlyArray<string>): void {
    if (!sportsList) return;
    if (sports.length === 0) {
      sportsList.innerHTML = '<li class="text-text-tertiary">No sports configured.</li>';
      return;
    }
    sportsList.innerHTML = sports.map((s) => `<li>${escapeHtml(s)}</li>`).join('');
  }

  async function loadOrgConfig(): Promise<void> {
    clearFormError();
    let res: Response;
    try {
      res = await fetch('/api/v1/admin/org', {
        credentials: 'same-origin',
        headers: { accept: 'application/json' },
      });
    } catch {
      showFormError('Could not reach the server.');
      return;
    }
    let body: ApiEnvelope | null;
    try {
      body = (await res.json()) as ApiEnvelope;
    } catch {
      showFormError('Unexpected server response.');
      return;
    }
    if (!res.ok || body?.success !== true || !body.data) {
      showFormError(body?.error?.message ?? 'Could not load organization configuration.');
      return;
    }
    const cfg = body.data;
    if (nameInput) nameInput.value = cfg.name;
    if (primaryColorInput) primaryColorInput.value = cfg.primaryColorHex ?? '';
    if (contactEmailInput) contactEmailInput.value = cfg.contactEmail ?? '';
    if (contactPhoneInput) contactPhoneInput.value = cfg.contactPhone ?? '';
    hydrateSports(cfg.sports);
    // Fire an `input` event so the form's own evaluator (bound on
    // `form.addEventListener('input', update)`) recomputes the
    // submit-enabled gate and field-error surface against the
    // hydrated values rather than the empty skeleton defaults.
    if (form) {
      form.dispatchEvent(new Event('input', { bubbles: true }));
    }
  }

  void loadOrgConfig();
</script>
