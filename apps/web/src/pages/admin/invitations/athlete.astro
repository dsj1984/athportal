---
// apps/web/src/pages/admin/invitations/athlete.astro
//
// /admin/invitations/athlete — the direct athlete invitation page
// (Epic #10 / Story #662 / Task #681). Org-admin surface: lets an
// admin invite an athlete directly to a single team in their org,
// bypassing the coach-driven invitation flow.
//
// The page is a thin Astro shell that renders an h1 + the
// `AthleteInviteForm` island. The island owns the team picker fetch
// and the POST submit; the shell exists so the page has a route, a
// title, and a landmark heading for the acceptance scenario to
// anchor on.
//
// Auth gating lives upstream — the Astro middleware redirects
// anonymous callers to sign-in, and the API endpoint the form posts
// to is gated by `requireRole('org_admin')` per Tech Spec #647. The
// page therefore assumes the caller has reached it legitimately and
// does not re-check role server-side.
import { requireAdminSsr } from '../../../lib/ssrAuthGate';

// SSR auth gate (Story #952 F4). Anonymous → 302 /sign-in; signed-in
// non-admin → 404 (non-enumeration per Epic #11 AC-2/AC-3). The page
// chrome must not render to non-admin callers, even though the inline
// client-script fetch would 403 a moment later.
import AthleteInviteForm from '../../../components/admin/invitations/AthleteInviteForm.astro';
const __ssr_gate = await requireAdminSsr(Astro);
if (__ssr_gate) return __ssr_gate;

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Invite an athlete</title>
  </head>
  <body>
    <main aria-label="Invite an athlete">
      <h1>Invite an athlete</h1>
      <AthleteInviteForm />
    </main>
  </body>
</html>
