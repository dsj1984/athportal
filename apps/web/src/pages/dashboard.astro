---
// apps/web/src/pages/dashboard.astro
//
// Post-onboarding landing surface. Composes the canonical
// page-chrome primitive (PageHeader), the bordered-surface primitive
// (Card), and the empty-state primitive (EmptyState). At MVP the
// dashboard reads no real data; the page hands `EMPTY_DASHBOARD_DATA`
// to `buildDashboard` so the freshly-onboarded view is exercised
// end-to-end. When real readers wire in, swap the constant for the
// live query and the empty-state branches stay identical.
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md) — utility
// classes resolve against the @theme tokens declared in
// apps/web/src/styles/global.css; no orphan BEM hooks. Palette and
// typography per docs/style-guide.md §3, page chrome per §4.
//
// Story #836 / Task #847 — Epic #828 dashboard surface.
import { listUserTeamsBySubject } from '@repo/shared/db/queries/userTeams';
import Card from '../components/ui/Card.astro';
import EmptyState from '../components/ui/EmptyState.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import RootLayout from '../layouts/RootLayout.astro';
import { getDb } from '../lib/db';
import { isAdminBySsr, requireSignedIn } from '../lib/ssrAuthGate';
import {
  EMPTY_DASHBOARD_DATA,
  type DashboardTeamRow,
  buildDashboard,
  buildRosterRows,
} from './_dashboard.ts';

// SSR auth gate (Story #952 F1). Anonymous requests must not see the
// dashboard chrome — the prior shape returned 200-with-chrome to a bare
// `curl` call, which leaked the surface's existence. Onboarding redirect
// stays in the middleware chain (see `apps/web/src/middleware.ts`).
const gate = requireSignedIn(Astro);
if (gate) return gate;

// Story #1086 — persona-aware landing routing. The generic dashboard
// (roster + activity + upcoming) has no affordance to the `/admin/*`
// surfaces an org-admin's role grants, which left a signed-in org-admin
// stranded on `/dashboard` with no discoverable path to their tools.
// Route them to the canonical admin landing (`/admin` → `/admin/teams`),
// where the shared App Shell header carries nav to every admin surface.
//
// The org-admin determination is server-side and driven by `users.role`:
// `isAdminBySsr` probes `GET /api/v1/admin/teams`, which the API edge
// gates with `requireRole('org_admin')`. A non-admin (member / athlete /
// anonymous-but-here) returns `false` and falls through to the generic
// dashboard below — non-admin callers see no admin affordance.
if (await isAdminBySsr(Astro)) {
  return Astro.redirect('/admin', 302);
}

// Story #985 / F27 — the Roster widget surfaces every team the signed-in
// user belongs to (coach assignments + athlete memberships). The web
// runtime only sees the Clerk `sub` claim; the query resolves the
// internal user id itself. A DB read failure must not 500 the whole
// dashboard — fall back to the empty-roster view, matching the
// safe-default posture the onboarding gate takes (middleware.ts).
const clerkSubjectId = Astro.locals.auth().userId;
let rosterRows: DashboardTeamRow[] = [];
if (typeof clerkSubjectId === 'string' && clerkSubjectId.length > 0) {
  try {
    rosterRows = buildRosterRows(listUserTeamsBySubject(getDb(), clerkSubjectId));
  } catch (cause) {
    const message = cause instanceof Error ? cause.message : String(cause);
    console.error(`[dashboard] roster read failed; rendering empty roster. Cause: ${message}`);
    rosterRows = [];
  }
}

const view = buildDashboard({ ...EMPTY_DASHBOARD_DATA, roster: rosterRows });
---

<RootLayout title="Dashboard">
  <main class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
    <PageHeader title="Dashboard" intro="Your post-onboarding home." />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        view.widgets.map((widget) => (
          <section data-testid={widget.id}>
            <Card soft>
              <h2 class="font-display text-lg font-semibold text-text-primary">{widget.heading}</h2>
              {widget.isEmpty ? (
                <div class="mt-4">
                  <EmptyState {...widget.emptyState} />
                </div>
              ) : widget.id === 'dashboard-widget-roster' ? (
                <ul class="mt-4 flex flex-col gap-2">
                  {(widget.rows as readonly DashboardTeamRow[]).map((team, idx) => (
                    <li
                      class="flex items-center justify-between gap-2 rounded-md border border-border bg-surface-bg px-3 py-2 text-sm"
                      data-row-index={idx}
                      data-testid="dashboard-roster-team"
                      data-team-id={team.teamId}
                    >
                      {team.href ? (
                        <a
                          class="font-medium text-text-primary underline-offset-2 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
                          href={team.href}
                          data-testid="dashboard-roster-team-link"
                        >
                          {team.teamName}
                        </a>
                      ) : (
                        <span class="font-medium text-text-primary">{team.teamName}</span>
                      )}
                      <span
                        class="rounded-full bg-surface-subtle px-2 py-0.5 text-xs font-medium text-text-secondary"
                        data-testid={
                          team.role === 'coach'
                            ? 'dashboard-roster-coach-badge'
                            : 'dashboard-roster-athlete-badge'
                        }
                      >
                        {team.role === 'coach' ? 'Coach' : 'Athlete'}
                      </span>
                    </li>
                  ))}
                </ul>
              ) : (
                <ul class="mt-4 flex flex-col gap-2">
                  {widget.rows.map((_row, idx) => (
                    <li
                      class="rounded-md border border-border bg-surface-bg px-3 py-2 text-sm text-text-secondary"
                      data-row-index={idx}
                    />
                  ))}
                </ul>
              )}
            </Card>
          </section>
        ))
      }
    </div>
  </main>
</RootLayout>
