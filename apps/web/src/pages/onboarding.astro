---
// apps/web/src/pages/onboarding.astro
//
// The `/onboarding` route. Composes the five islands that drive a
// freshly-authenticated user through email verification, name
// collection, legal acceptance, age attestation, and the optional
// profile-photo upload before the API-side `requireOnboarded` gate
// lets them through to any `/api/v1/*` surface.
//
// The route SSR-fetches the active legal documents so the
// LegalAcceptanceCheckboxes island binds to the same version strings
// the API edge re-validates against — there is no client-side fetch
// of the legal versions, which keeps the form's payload deterministic
// for the round-trip.
//
// Reads the active Terms-of-Service / Privacy-Policy rows from the
// runtime DB at SSR time via the sanctioned `getActiveLegalDocuments`
// accessor in `@repo/shared/db/queries/legalDocuments`. The page wires
// the row versions into the `OnboardingForm` so the client submission
// carries the exact version strings the API edge re-validates against —
// there is no client-side fetch of the legal versions, which keeps the
// payload deterministic for the round-trip.
//
// Story #878 / Task #891 — Web runtime DB binding cutover replaces the
// previous `readActiveLegalDocumentsPlaceholder()` (which mirrored the
// `SEED_*` constants verbatim) with a live DB read. The page now tracks
// any future legal-documents row update without a code change. The
// underlying accessor still throws when either active row is missing —
// an un-seeded environment is a configuration error, not a runtime
// condition. Story #574 / Task #580 (PRD #489 / Tech Spec #490)
// introduced the original placeholder.

import { buildOnboardingPageView } from './onboarding.ts';
import { getActiveLegalDocuments } from '@repo/shared/db/queries/legalDocuments';
import OnboardingForm from '../components/onboarding/OnboardingForm.astro';
import RootLayout from '../layouts/RootLayout.astro';
import { getDb } from '../lib/db';

const activeLegalDocuments = getActiveLegalDocuments(getDb());
const view = buildOnboardingPageView(activeLegalDocuments);

// Invite token is carried on the URL as `/onboarding?invite=<token>`
// (see the parent/coach invite-acceptance flow). Read it server-side
// and hand it to the form as a prop so the inline submit script can
// include it in the OnboardInput payload; an empty / missing param
// becomes `null` and the payload omits the field entirely.
const rawInviteToken = Astro.url.searchParams.get('invite');
const inviteToken =
  typeof rawInviteToken === 'string' && rawInviteToken.length > 0 ? rawInviteToken : null;
---

<RootLayout title={view.title}>
  <main class="mx-auto flex w-full max-w-2xl flex-col gap-4 px-4 py-8">
    <h1 class="font-display text-2xl font-semibold text-text-primary">{view.heading}</h1>
    <p class="text-sm text-text-secondary">{view.intro}</p>

    <OnboardingForm
      termsOfServiceVersion={view.legalAcceptances.termsOfServiceVersion}
      privacyPolicyVersion={view.legalAcceptances.privacyPolicyVersion}
      inviteToken={inviteToken}
    />
  </main>
</RootLayout>
