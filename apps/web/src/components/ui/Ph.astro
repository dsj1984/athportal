---
// apps/web/src/components/ui/Ph.astro
//
// Striped-placeholder primitive with a system-mono label. Used at
// design-time and on the styleguide page to mark slots that will be
// filled by real content later. No JetBrains Mono import — the label
// is rendered in --font-mono (system mono stack) per
// global.css.
//
// Story #713 / Task #728 — Epic #702 design system.

import { type PhProps, buildPhView } from './Ph.ts';

type Props = PhProps;
const view = buildPhView(Astro.props);
---

<div class={view.rootClass} style={view.style} data-testid="ph">
  <span class={view.labelClass}>{view.label}</span>
</div>
