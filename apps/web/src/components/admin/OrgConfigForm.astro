---
// apps/web/src/components/admin/OrgConfigForm.astro
//
// Renders the admin org-config form's controlled surface: organization
// name, sports (placeholder list — read-only on this Story until the
// matching schema columns land), contact email/phone (placeholder),
// primary colour, and the logo upload control.
//
// Browser-side behavior:
//   • The inline script reads working state from the form's inputs,
//     runs `evaluateOrgConfigFormState` after every change, and toggles
//     the submit button's `disabled` attribute against the result.
//   • On logo selection, the script POSTs to
//     `/api/v1/admin/org/logo-upload-url` to mint a presigned URL,
//     PUTs the file body, then POSTs the resulting key to
//     `/api/v1/admin/org/logo-finalize` to persist the row update.
//   • On form submit, `tryBuildOrgConfigPatchPayload` converts the
//     working state into the strict OrgConfigPatchInput payload and
//     PATCHes /api/v1/admin/org. A success swaps the status element to
//     read "Saved"; a 400 envelope folds back into per-field errors.
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md) — utility
// classes resolve against the @theme tokens declared in
// apps/web/src/styles/global.css; no orphan BEM hooks. Each labelled
// field composes the FormField primitive (Story #837).
//
// Story #656 / Task #674. Restyled by Story #842 / Task #852.

import { ORG_CONFIG_FORM_TEST_IDS } from './OrgConfigForm.ts';
import type { OrgConfigLoaderPayload } from './OrgConfigForm.ts';
import FormField from '../ui/FormField.astro';

interface Props {
  readonly loader: OrgConfigLoaderPayload;
}
const { loader } = Astro.props;

const inputClass =
  'rounded-md border border-border bg-surface-card px-3 py-2 text-sm text-text-primary shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand disabled:cursor-not-allowed disabled:opacity-60';
const fieldErrorClass = 'text-xs text-action-coral';
---

<form
  class="flex flex-col gap-4"
  data-testid={ORG_CONFIG_FORM_TEST_IDS.form}
  novalidate
>
  <p
    class="rounded-md border border-action-coral bg-surface-card p-3 text-sm text-action-coral"
    data-testid={ORG_CONFIG_FORM_TEST_IDS.formError}
    role="alert"
    hidden
  ></p>

  <FormField label="Organization name" htmlFor="admin-org-name" required>
    <input
      id="admin-org-name"
      name="name"
      type="text"
      class={inputClass}
      data-testid={ORG_CONFIG_FORM_TEST_IDS.name}
      value={loader.name}
      required
      maxlength="200"
    />
    <p class={fieldErrorClass} data-field-error="name" hidden></p>
  </FormField>

  <FormField label="Sports" htmlFor="admin-org-sports">
    <ul
      id="admin-org-sports"
      class="flex flex-col gap-1 text-sm text-text-secondary"
      data-testid="admin-org-sports-list"
    >
      {loader.sports.length === 0
        ? <li class="text-text-tertiary">No sports configured.</li>
        : loader.sports.map((s) => <li>{s}</li>)
      }
    </ul>
  </FormField>

  <FormField label="Contact email" htmlFor="admin-org-contact-email">
    <input
      id="admin-org-contact-email"
      name="contactEmail"
      type="email"
      class={inputClass}
      data-testid="admin-org-contact-email-input"
      value={loader.contactEmail ?? ''}
      disabled
    />
  </FormField>

  <FormField label="Contact phone" htmlFor="admin-org-contact-phone">
    <input
      id="admin-org-contact-phone"
      name="contactPhone"
      type="tel"
      class={inputClass}
      data-testid="admin-org-contact-phone-input"
      value={loader.contactPhone ?? ''}
      disabled
    />
  </FormField>

  <FormField label="Logo" htmlFor="admin-org-logo">
    <input
      id="admin-org-logo"
      name="logo"
      type="file"
      accept="image/png,image/jpeg,image/webp"
      class="text-sm text-text-primary file:mr-3 file:rounded-md file:border file:border-border file:bg-surface-card file:px-3 file:py-1 file:text-sm file:text-text-primary"
      data-testid={ORG_CONFIG_FORM_TEST_IDS.logo}
    />
    <p class={fieldErrorClass} data-field-error="logo" hidden></p>
    {loader.logoUrl
      ? <img
          class="mt-2 h-16 w-16 rounded-md border border-border object-cover"
          src={loader.logoUrl}
          alt="Current logo"
        />
      : null
    }
  </FormField>

  <FormField label="Primary colour" htmlFor="admin-org-primary-color">
    <input
      id="admin-org-primary-color"
      name="primaryColorHex"
      type="text"
      class={inputClass}
      data-testid={ORG_CONFIG_FORM_TEST_IDS.primaryColor}
      value={loader.primaryColorHex ?? ''}
      placeholder="#RRGGBB"
      maxlength="7"
    />
    <p class={fieldErrorClass} data-field-error="primaryColorHex" hidden></p>
  </FormField>

  <button
    type="submit"
    class="inline-flex items-center justify-center rounded-md bg-brand px-4 py-2 text-sm font-medium text-text-on-brand shadow-sm hover:bg-brand-strong focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand disabled:cursor-not-allowed disabled:opacity-60"
    data-testid={ORG_CONFIG_FORM_TEST_IDS.submit}
  >
    Save changes
  </button>

  <p
    class="text-sm text-text-secondary"
    data-testid={ORG_CONFIG_FORM_TEST_IDS.status}
    role="status"
    aria-live="polite"
  ></p>
</form>

<script>
  import {
    ORG_CONFIG_FORM_TEST_IDS as TEST_IDS,
    evaluateOrgConfigFormState,
    foldServerErrorIntoFieldMap,
    tryBuildOrgConfigPatchPayload,
    type OrgConfigFormState,
  } from './OrgConfigForm.ts';

  const form = document.querySelector<HTMLFormElement>(`[data-testid="${TEST_IDS.form}"]`);
  const submit = document.querySelector<HTMLButtonElement>(
    `[data-testid="${TEST_IDS.submit}"]`,
  );
  const status = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.status}"]`,
  );
  const formError = document.querySelector<HTMLElement>(
    `[data-testid="${TEST_IDS.formError}"]`,
  );
  const logoInput = document.querySelector<HTMLInputElement>(
    `[data-testid="${TEST_IDS.logo}"]`,
  );

  if (form && submit && status) {
    let logoR2Key: string | null = null;

    const readState = (): OrgConfigFormState => {
      const data = new FormData(form);
      return {
        name: String(data.get('name') ?? ''),
        primaryColorHex: String(data.get('primaryColorHex') ?? ''),
        logoR2Key,
      };
    };

    const renderFieldErrors = (
      errors: Readonly<Partial<Record<string, string>>>,
    ) => {
      const containers = form.querySelectorAll<HTMLElement>('[data-field-error]');
      containers.forEach((el) => {
        const key = el.dataset.fieldError ?? '';
        const msg = errors[key];
        if (typeof msg === 'string' && msg.length > 0) {
          el.textContent = msg;
          el.hidden = false;
        } else {
          el.textContent = '';
          el.hidden = true;
        }
      });
      if (formError) {
        const top = errors.form ?? '';
        if (top.length > 0) {
          formError.textContent = top;
          formError.hidden = false;
        } else {
          formError.textContent = '';
          formError.hidden = true;
        }
      }
    };

    const update = () => {
      const state = readState();
      const evaluation = evaluateOrgConfigFormState(state);
      submit.disabled = !evaluation.canSubmit;
      renderFieldErrors(evaluation.fieldErrors);
    };

    form.addEventListener('input', update);
    form.addEventListener('change', update);

    if (logoInput) {
      logoInput.addEventListener('change', async () => {
        const file = logoInput.files?.[0];
        if (!file) return;
        try {
          const mint = await fetch('/api/v1/admin/org/logo-upload-url', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ contentType: file.type, contentLength: file.size }),
          });
          if (!mint.ok) {
            const envelope = (await mint.json().catch(() => null)) as {
              error?: { message?: string };
            } | null;
            renderFieldErrors({ logo: envelope?.error?.message ?? 'Upload rejected.' });
            return;
          }
          const mintBody = (await mint.json()) as { data: { uploadUrl: string; key: string } };
          const put = await fetch(mintBody.data.uploadUrl, {
            method: 'PUT',
            headers: { 'content-type': file.type },
            body: file,
          });
          if (!put.ok) {
            renderFieldErrors({ logo: 'Upload failed.' });
            return;
          }
          const finalize = await fetch('/api/v1/admin/org/logo-finalize', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ key: mintBody.data.key }),
          });
          if (!finalize.ok) {
            renderFieldErrors({ logo: 'Finalize failed.' });
            return;
          }
          logoR2Key = mintBody.data.key;
          renderFieldErrors({});
        } catch {
          renderFieldErrors({ logo: 'Network error during upload.' });
        }
      });
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const state = readState();
      const result = tryBuildOrgConfigPatchPayload(state);
      if (!result.ok) {
        renderFieldErrors(result.fieldErrors);
        return;
      }
      submit.disabled = true;
      try {
        const response = await fetch('/api/v1/admin/org', {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(result.value),
        });
        if (response.ok) {
          status.textContent = 'Saved';
          renderFieldErrors({});
          return;
        }
        const envelope = (await response.json().catch(() => null)) as {
          error?: { code?: string; message?: string };
        } | null;
        const errors = envelope?.error
          ? foldServerErrorIntoFieldMap(envelope.error)
          : { form: 'Could not save changes.' };
        renderFieldErrors(errors);
      } catch {
        renderFieldErrors({ form: 'Could not reach the server.' });
      } finally {
        submit.disabled = false;
      }
    });

    update();
  }
</script>
