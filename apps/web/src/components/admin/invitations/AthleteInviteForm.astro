---
// apps/web/src/components/admin/invitations/AthleteInviteForm.astro
//
// Direct-athlete-invitation form island for /admin/invitations/athlete
// (Epic #10 / Story #662 / Task #681).
//
// Server-renders an email input + a single-team `<select>` picker
// populated from `GET /api/v1/admin/teams`, then submits a single
// JSON POST to `/api/v1/admin/invitations/athlete`. On success the
// status region reads "Invitation sent"; on failure it reads the
// server's error message verbatim. The picker stays a single-select
// (no multi-team) — direct invites are scoped to one team by design
// per Tech Spec #647.
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md) — utility
// classes resolve against the @theme tokens declared in
// apps/web/src/styles/global.css; no orphan BEM hooks. Each labelled
// field composes the FormField primitive. Restyled by Story #851 /
// Task #859.
//
// `data-testid` invariance (locked by the Tech Spec — acceptance
// scenario #682 pins these names):
//
//   - admin-athlete-invite-form
//   - admin-athlete-invite-team-picker
//   - admin-athlete-invite-status

import FormField from '../../ui/FormField.astro';

const inputClass =
  'rounded-md border border-border bg-surface-card px-3 py-2 text-sm text-text-primary shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand disabled:cursor-not-allowed disabled:opacity-60';
---

<section class="flex flex-col gap-4">
  <h2 class="font-display text-lg font-semibold text-text-primary">Invite an athlete</h2>
  <form
    class="flex flex-col gap-4"
    data-testid="admin-athlete-invite-form"
    novalidate
  >
    <FormField label="Athlete email" htmlFor="athlete-invite-email" required>
      <input
        id="athlete-invite-email"
        name="email"
        type="email"
        class={inputClass}
        required
        maxlength="254"
        autocomplete="off"
      />
    </FormField>

    <FormField label="Team" htmlFor="athlete-invite-team" required>
      <select
        id="athlete-invite-team"
        name="teamId"
        class={inputClass}
        data-testid="admin-athlete-invite-team-picker"
        required
      >
        <option value="">Loading teams…</option>
      </select>
    </FormField>

    <button
      type="submit"
      class="inline-flex items-center justify-center rounded-md bg-brand px-4 py-2 text-sm font-medium text-text-on-brand shadow-sm hover:bg-brand-strong focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand disabled:cursor-not-allowed disabled:opacity-60"
    >
      Send invitation
    </button>

    <p
      class="text-sm text-text-secondary"
      data-testid="admin-athlete-invite-status"
      role="status"
      aria-live="polite"
    ></p>
  </form>
</section>

<script>
  // Per Tech Spec #647: the page calls `GET /api/v1/admin/teams` to
  // populate the picker, then submits `POST
  // /api/v1/admin/invitations/athlete` with `{ email, teamId }`. The
  // status region carries the user-visible outcome the acceptance
  // scenario asserts on.

  interface TeamRow {
    readonly id: string;
    readonly name: string;
  }

  interface TeamListResponse {
    readonly success: true;
    readonly data: readonly TeamRow[];
  }

  interface InviteSuccessResponse {
    readonly success: true;
  }

  interface ErrorResponse {
    readonly success: false;
    readonly error: { readonly code: string; readonly message: string };
  }

  function isTeamListResponse(x: unknown): x is TeamListResponse {
    if (typeof x !== 'object' || x === null) return false;
    const o = x as { success?: unknown; data?: unknown };
    return o.success === true && Array.isArray(o.data);
  }

  function isInviteSuccessResponse(x: unknown): x is InviteSuccessResponse {
    if (typeof x !== 'object' || x === null) return false;
    return (x as { success?: unknown }).success === true;
  }

  function isErrorResponse(x: unknown): x is ErrorResponse {
    if (typeof x !== 'object' || x === null) return false;
    const o = x as { success?: unknown; error?: unknown };
    return o.success === false && typeof o.error === 'object' && o.error !== null;
  }

  async function loadTeams(picker: HTMLSelectElement): Promise<void> {
    try {
      const res = await fetch('/api/v1/admin/teams', {
        method: 'GET',
        credentials: 'include',
      });
      if (!res.ok) {
        picker.innerHTML = '<option value="">Could not load teams.</option>';
        return;
      }
      const body: unknown = await res.json();
      if (!isTeamListResponse(body)) {
        picker.innerHTML = '<option value="">Could not load teams.</option>';
        return;
      }
      if (body.data.length === 0) {
        picker.innerHTML = '<option value="">No teams available.</option>';
        return;
      }
      const placeholder = document.createElement('option');
      placeholder.value = '';
      placeholder.textContent = 'Select a team';
      picker.innerHTML = '';
      picker.appendChild(placeholder);
      for (const team of body.data) {
        const opt = document.createElement('option');
        opt.value = team.id;
        opt.textContent = team.name;
        picker.appendChild(opt);
      }
    } catch {
      picker.innerHTML = '<option value="">Could not load teams.</option>';
    }
  }

  function setStatus(form: HTMLFormElement, text: string): void {
    const status = form.querySelector<HTMLElement>(
      '[data-testid="admin-athlete-invite-status"]',
    );
    if (status) status.textContent = text;
  }

  const form = document.querySelector<HTMLFormElement>(
    '[data-testid="admin-athlete-invite-form"]',
  );
  if (form) {
    const picker = form.querySelector<HTMLSelectElement>(
      '[data-testid="admin-athlete-invite-team-picker"]',
    );
    const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
    const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');

    if (picker) void loadTeams(picker);

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!picker || !emailInput) return;
      const email = emailInput.value.trim();
      const teamId = picker.value;
      if (email.length === 0 || teamId.length === 0) {
        setStatus(form, 'Please enter an email and select a team.');
        return;
      }
      if (submit) submit.disabled = true;
      setStatus(form, 'Sending…');
      try {
        const res = await fetch('/api/v1/admin/invitations/athlete', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email, teamId }),
        });
        const body: unknown = await res.json().catch(() => null);
        if (res.ok && isInviteSuccessResponse(body)) {
          setStatus(form, 'Invitation sent');
          emailInput.value = '';
          picker.value = '';
          return;
        }
        if (isErrorResponse(body)) {
          setStatus(form, body.error.message);
        } else {
          setStatus(form, 'We could not send the invitation. Try again in a moment.');
        }
      } catch {
        setStatus(form, 'We could not reach the server. Check your connection and try again.');
      } finally {
        if (submit) submit.disabled = false;
      }
    });
  }
</script>
