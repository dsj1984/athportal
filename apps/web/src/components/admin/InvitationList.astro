---
// apps/web/src/components/admin/InvitationList.astro
//
// Pending-invitations table island for the /admin/invitations page
// (Epic #10 / Story #655 / Task #669).
//
// Server-renders an initial empty table shell with the stable
// `data-testid="admin-invitations-list"` selector the Tech Spec
// pins, then hands over to an inline script that fetches the
// initial list from `GET /api/v1/admin/invitations` and wires the
// resend / revoke buttons to their respective POST endpoints. On
// revoke the row is removed from the DOM in place — no full-page
// reload — which is the user-visible contract the acceptance
// scenario (Task #667) asserts.
//
// Styling follows the Tailwind-utility-first convention codified by
// ADR-0007 (docs/decisions/0007-ui-styling-convention.md) — utility
// classes resolve against the @theme tokens declared in
// apps/web/src/styles/global.css; no orphan BEM hooks. The list
// chrome composes the shared DataTable primitive; the prior
// `.invitation-list__*` class hooks are replaced by `data-*`
// attribute hooks that the inline script targets. Restyled by
// Story #851 / Task #859.
//
// `data-testid` invariance (locked by the Tech Spec):
//
//   - admin-invitations-list           (table wrapper)
//   - admin-invitation-resend-btn      (one per row)
//   - admin-invitation-revoke-btn      (one per row)

import DataTable from '../ui/DataTable.astro';
---

<section class="flex flex-col gap-3" data-admin-invitations>
  <h2 class="font-display text-lg font-semibold text-text-primary">Pending invitations</h2>
  <p
    class="text-sm text-text-secondary"
    data-testid="admin-invitations-status"
    data-invitations-status
  >
    Loading…
  </p>
  <div data-invitations-table hidden>
    <DataTable
      testId="admin-invitations-list"
      tbodyTestId="admin-invitations-tbody"
      columns={[
        { key: 'email', label: 'Email' },
        { key: 'role', label: 'Role' },
        { key: 'sent', label: 'Sent' },
        { key: 'actions', label: 'Actions', align: 'end' },
      ]}
    />
  </div>

  <template data-invitations-row-template>
    <tr
      class="text-sm text-text-primary [&_td]:px-3 [&_td]:py-2"
      data-invitations-row
    >
      <td data-invitations-email></td>
      <td data-invitations-role></td>
      <td data-invitations-created></td>
      <td class="text-right">
        <div class="inline-flex items-center gap-2">
          <button
            type="button"
            class="inline-flex items-center justify-center rounded-md border border-border bg-surface-card px-2 py-1 text-xs text-text-primary hover:bg-surface-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
            data-testid="admin-invitation-resend-btn"
            data-invitations-resend
          >
            Resend
          </button>
          <button
            type="button"
            class="inline-flex items-center justify-center rounded-md border border-action-coral bg-surface-card px-2 py-1 text-xs text-action-coral hover:bg-surface-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-action-coral"
            data-testid="admin-invitation-revoke-btn"
            data-invitations-revoke
          >
            Revoke
          </button>
        </div>
      </td>
    </tr>
  </template>
</section>

<script lang="ts">
  // Per Tech Spec #647: the page calls the admin invitations API and
  // mutates the list in place on resend / revoke. The script lives in
  // the page island rather than a shared bundle because the surface
  // is small and the dependency footprint is zero — pulling in React
  // for one table is the wrong trade-off at this scope.

  interface InvitationRow {
    readonly id: string;
    readonly email: string;
    readonly role: 'coach' | 'athlete';
    readonly createdAt: number;
  }

  interface ListResponse {
    readonly success: true;
    readonly data: readonly InvitationRow[];
  }

  function isListResponse(x: unknown): x is ListResponse {
    if (typeof x !== 'object' || x === null) return false;
    const o = x as { success?: unknown; data?: unknown };
    return o.success === true && Array.isArray(o.data);
  }

  function format(ts: number): string {
    return new Date(ts * 1000).toLocaleString();
  }

  function render(root: HTMLElement, rows: readonly InvitationRow[]): void {
    const status = root.querySelector<HTMLElement>('[data-invitations-status]');
    const tableWrap = root.querySelector<HTMLElement>('[data-invitations-table]');
    const tbody = root.querySelector<HTMLTableSectionElement>(
      '[data-testid="admin-invitations-tbody"]',
    );
    const template = root.querySelector<HTMLTemplateElement>(
      '[data-invitations-row-template]',
    );
    if (!status || !tableWrap || !tbody || !template) return;

    tbody.innerHTML = '';
    if (rows.length === 0) {
      status.textContent = 'No pending invitations.';
      tableWrap.hidden = true;
      return;
    }

    status.textContent = '';
    tableWrap.hidden = false;
    for (const row of rows) {
      const fragment = template.content.cloneNode(true) as DocumentFragment;
      const tr = fragment.querySelector<HTMLTableRowElement>('[data-invitations-row]');
      if (!tr) continue;
      tr.dataset.invitationId = row.id;
      const email = tr.querySelector<HTMLElement>('[data-invitations-email]');
      const role = tr.querySelector<HTMLElement>('[data-invitations-role]');
      const created = tr.querySelector<HTMLElement>('[data-invitations-created]');
      if (email) email.textContent = row.email;
      if (role) role.textContent = row.role;
      if (created) created.textContent = format(row.createdAt);
      tbody.appendChild(fragment);
    }
  }

  async function load(root: HTMLElement): Promise<void> {
    const res = await fetch('/api/v1/admin/invitations', {
      method: 'GET',
      credentials: 'include',
    });
    if (!res.ok) {
      const status = root.querySelector<HTMLElement>('[data-invitations-status]');
      if (status) status.textContent = 'Failed to load invitations.';
      return;
    }
    const body: unknown = await res.json();
    if (!isListResponse(body)) return;
    render(root, body.data);
  }

  function bind(root: HTMLElement): void {
    root.addEventListener('click', async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const row = target.closest<HTMLTableRowElement>('[data-invitations-row]');
      const id = row?.dataset.invitationId;
      if (!id) return;

      if (target.closest('[data-invitations-resend]')) {
        await fetch(`/api/v1/admin/invitations/${encodeURIComponent(id)}/resend`, {
          method: 'POST',
          credentials: 'include',
        });
        return;
      }

      if (target.closest('[data-invitations-revoke]')) {
        const res = await fetch(`/api/v1/admin/invitations/${encodeURIComponent(id)}/revoke`, {
          method: 'POST',
          credentials: 'include',
        });
        if (res.ok && row) {
          row.remove();
          // If the table is empty post-remove, flip back to the empty
          // status copy so the user sees the same state they would
          // after a fresh load with no invitations.
          const tbody = root.querySelector<HTMLTableSectionElement>(
            '[data-testid="admin-invitations-tbody"]',
          );
          if (tbody && tbody.children.length === 0) {
            const status = root.querySelector<HTMLElement>('[data-invitations-status]');
            const tableWrap = root.querySelector<HTMLElement>('[data-invitations-table]');
            if (status) status.textContent = 'No pending invitations.';
            if (tableWrap) tableWrap.hidden = true;
          }
        }
      }
    });
  }

  const root = document.querySelector<HTMLElement>('[data-admin-invitations]');
  if (root) {
    bind(root);
    void load(root);
  }
</script>
