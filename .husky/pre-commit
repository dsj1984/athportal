#!/usr/bin/env sh
# Pre-commit hook — Athlete Portal.
#
# Four-stage guard:
#   1. Block any staged path under `.agents/` (the framework submodule).
#      Per AGENTS.md §Safety Constraints, that directory is managed only
#      via `/agents-update` — direct edits are forbidden.
#   2. Run lint-staged (biome + markdownlint + secretlint) on the staged
#      set only so the hook stays fast on large diffs. The per-extension
#      fan-out lives in lint-staged.config.js.
#   3. Run the stabilized quality gates (Epic #1386 / Story #1401) on the
#      staged diff so MI/CRAP drift is caught at commit time.
#   4. Run the step-definition linter against staged step/feature files.

# --- 1. .agents/ write-guard ---------------------------------------------
staged_agents=$(git diff --cached --name-only --diff-filter=ACMR | grep '^\.agents/' || true)
if [ -n "$staged_agents" ]; then
	echo "✖ pre-commit: refusing to commit changes under .agents/" >&2
	echo "" >&2
	echo "  The .agents/ tree is a git submodule managed by /agents-update." >&2
	echo "  See AGENTS.md §Safety Constraints — do not edit .agents/ directly." >&2
	echo "" >&2
	echo "  Staged paths:" >&2
	echo "$staged_agents" | sed 's/^/    /' >&2
	exit 1
fi

# --- 2. lint-staged on staged files --------------------------------------
# lint-staged.config.js is the single source of truth for staged-file
# linters: biome (ts/tsx/js/jsx/mjs/cjs/json/jsonc/css), markdownlint
# (md/markdown only), and secretlint (any extension). Keeping biome
# wired through lint-staged — instead of a bare `biome check --staged`
# line here — prevents accidental double-runs when a future contributor
# adds another biome entry.
pnpm exec lint-staged

# --- 3. Stabilized quality gates on staged diff --------------------------
# quality:preview wraps the MI and CRAP gates with --changed-since HEAD
# --staged and exits non-zero on any threshold violation, blocking the
# commit and rendering the per-file delta table to stderr. See
# .agents/workflows/helpers/code-quality-guardrails.md.
node .agents/scripts/quality-preview.js --changed-since HEAD --staged

# --- 4. Step-definition linter on staged step/feature files --------------
# `lint:steps --staged` short-circuits via `git diff --cached --name-only` and
# exits 0 in <500ms when no step (apps/web/e2e/steps/**/*.ts) or feature
# (tests/features/**/*.feature) file is staged. When a step or feature file
# IS staged, the three rule classes documented in docs/testing-strategy.md
# (forbidden patterns, duplicate phrases, unused-step warning) are enforced.
pnpm run lint:steps --staged

# --- 5. RBAC matrix drift check ------------------------------------------
# Epic #9 / Story #616 — packages/shared/src/rbac/rules.ts is the source of
# truth for the RBAC matrix; docs/data-dictionary.md publishes it between
# sentinel comments. render-rbac-matrix.mjs --check re-derives the table
# from rules.ts and exits non-zero if the doc has drifted. Fix locally
# with `node scripts/render-rbac-matrix.mjs --write`.
if git diff --cached --name-only --diff-filter=ACMR | grep -qE '^packages/shared/src/rbac/rules\.ts$|^docs/data-dictionary\.md$|^scripts/render-rbac-matrix\.mjs$'; then
	node scripts/render-rbac-matrix.mjs --check
fi
