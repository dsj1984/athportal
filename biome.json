{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": [
      "**/src/**/*.ts",
      "**/src/**/*.tsx",
      "**/src/**/*.js",
      "**/src/**/*.mjs",
      "**/scripts/**/*.mjs",
      "**/scripts/**/*.ts",
      "**/vitest.config.ts",
      "**/vitest.workspace.ts",
      "**/vitest.base.ts",
      "**/vitest.contract.ts",
      "**/playwright.config.ts",
      "**/astro.config.ts",
      "**/app.config.ts",
      "**/drizzle.config.ts",
      "**/knip.config.ts",
      "**/e2e/**/*.ts",
      "**/e2e/**/*.tsx",
      "!**/dist",
      "!**/.turbo",
      "!**/.bdd-gen",
      "!**/test-results",
      "!**/node_modules",
      "!**/coverage",
      "!**/.agents",
      "!**/.worktrees",
      "!**/.stryker-tmp",
      "!**/reports",
      "!**/temp",
      "!**/scripts/__fixtures__"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "recommended": true,
        "noUnusedFunctionParameters": "off",
        "noUnusedImports": "off"
      },
      "suspicious": {
        "recommended": true,
        "noPrototypeBuiltins": "off",
        "noTemplateCurlyInString": "off",
        "noTsIgnore": "off",
        "useBiomeIgnoreFolder": "off"
      },
      "complexity": {
        "recommended": true,
        "noUselessEscapeInRegex": "off",
        "useOptionalChain": "off"
      },
      "security": {
        "recommended": true
      },
      "style": {
        "recommended": false
      }
    }
  },
  "assist": { "actions": { "source": { "organizeImports": "off" } } }
}
