{
  "name": "athportal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "node scripts/dev-preflight.mjs && turbo run dev --parallel",
    "db:seed": "pnpm --filter @repo/shared run db:seed",
    "db:reset": "pnpm --filter @repo/shared run db:reset",
    "lint": "pnpm -w run --parallel \"/^lint:(js|md)$/\"",
    "lint:js": "turbo run lint",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#**/node_modules/**\" \"#.agents/**\" \"#.claude/**\" \"#.worktrees/**\" \"#temp/**\" \"#**/dist/**\" \"#coverage/**\" \"#**/.bdd-gen/**\" \"#scripts/__fixtures__/**\" \"#**/.clerk/**\"",
    "lint:secrets": "secretlint --secretlintignore .gitignore --secretlintignore .secretlintignore \"**/*\"",
    "lint:biome": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "knip:strict": "knip --reporter compact",
    "knip:fast": "knip --include files,dependencies --reporter compact",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test && pnpm exec vitest run --project scripts",
    "test:coverage": "vitest run --coverage",
    "mutation": "stryker run",
    "build": "turbo run build",
    "lint:baseline:check": "node scripts/lint-baseline.mjs --check",
    "lint:baseline:update": "node scripts/lint-baseline.mjs --update",
    "coverage:check": "node scripts/coverage-baseline.mjs --check",
    "coverage:update": "node scripts/coverage-baseline.mjs --update",
    "crap:check": "node scripts/crap-baseline.mjs --check",
    "crap:update": "node scripts/crap-baseline.mjs --update",
    "maintainability:check": "node scripts/maintainability-baseline.mjs --check",
    "maintainability:update": "node scripts/maintainability-baseline.mjs --update",
    "bundle-size:check": "node scripts/bundle-size-baseline.mjs --check",
    "bundle-size:update": "node scripts/bundle-size-baseline.mjs --update",
    "mutation:check": "node scripts/mutation-baseline.mjs --check",
    "mutation:update": "node scripts/mutation-baseline.mjs --update",
    "lighthouse:check": "node scripts/lighthouse-baseline.mjs --check",
    "lighthouse:update": "node scripts/lighthouse-baseline.mjs --update",
    "lint:qa": "node scripts/qa/lint.mjs",
    "index:qa": "node scripts/qa/index.mjs",
    "coverage:qa": "node scripts/qa/coverage.mjs",
    "lint:steps": "node scripts/lint-steps.mjs",
    "lint:steps:fixtures": "node scripts/lint-steps.mjs --fixtures",
    "lint:deps": "depcruise apps packages --config .dependency-cruiser.cjs",
    "lint:deps:graph": "node scripts/dep-graph.mjs",
    "audit:check": "node scripts/audit-check.mjs",
    "sync:commands": "node .agents/scripts/sync-claude-commands.js && node scripts/sync-local-commands.mjs",
    "prepare": "node .agents/scripts/sync-claude-commands.js && node scripts/sync-local-commands.mjs",
    "quality:preview": "node .agents/scripts/quality-preview.js --changed-since HEAD",
    "quality:watch": "node .agents/scripts/quality-watch.js",
    "quality:ci-local": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run lint:baseline:check && pnpm run knip:strict && pnpm run lint:secrets && node scripts/lint-orphan-bem.mjs && node scripts/lint-astro-frontmatter.mjs"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.5",
    "picomatch": "^4.0.4",
    "string-argv": "^0.3.2",
    "typhonjs-escomplex": "^0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@stryker-mutator/core": "^9.2.0",
    "@stryker-mutator/vitest-runner": "^9.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "better-sqlite3": "^12.10.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "gray-matter": "^4.0.3",
    "knip": "^6.14.1",
    "lint-staged": "^17.0.5",
    "markdownlint-cli2": "^0.22.1",
    "secretlint": "^13.0.2",
    "turbo": "^2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "zod": "^3.23.8"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm@<0.45.2": ">=0.45.2",
      "@clerk/clerk-expo@<2.19.36": ">=2.19.36",
      "@clerk/clerk-react@<5.61.6": ">=5.61.6",
      "js-cookie@<3.0.7": ">=3.0.7"
    },
    "patchedDependencies": {
      "oxc-parser@0.130.0": "patches/oxc-parser@0.130.0.patch"
    }
  }
}
