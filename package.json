{
  "name": "athportal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "lint:baseline:check": "node .agents/scripts/lint-baseline-check.js",
    "lint:baseline:update": "node .agents/scripts/lint-baseline-update.js",
    "sync:commands": "node .agents/scripts/sync-claude-commands.js",
    "prepare": "node .agents/scripts/sync-claude-commands.js",
    "quality:preview": "node .agents/scripts/quality-preview.js --changed-since HEAD",
    "quality:watch": "node .agents/scripts/quality-watch.js"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.1",
    "picomatch": "^4.0.4",
    "string-argv": "^0.3.2",
    "typhonjs-escomplex": "^0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0"
  }
}
