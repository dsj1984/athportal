{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./src/testing/index.ts"
    }
  },
  "scripts": {
    "lint": "pnpm exec biome check src && pnpm exec eslint src",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "test": "pnpm exec vitest run",
    "build": "exit 0"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.0.0",
    "vitest": "^4.1.6",
    "zod": "^3.23.8"
  }
}
