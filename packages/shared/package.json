{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./src/testing/index.ts"
    },
    "./db/schema": {
      "types": "./dist/db/schema/index.d.ts",
      "import": "./src/db/schema/index.ts"
    },
    "./db/queries/users": {
      "types": "./dist/db/queries/users.d.ts",
      "import": "./src/db/queries/users.ts"
    },
    "./rbac": {
      "types": "./dist/rbac/index.d.ts",
      "import": "./src/rbac/index.ts"
    }
  },
  "scripts": {
    "lint": "pnpm exec biome check src && pnpm exec eslint src",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "test": "pnpm exec vitest run",
    "build": "exit 0"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.13",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.31",
    "@playwright/test": "^1.60.0",
    "@repo/config": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "drizzle-kit": "^0.30.0",
    "jsdom": "^26.0.0",
    "vitest": "^4.1.6"
  }
}
